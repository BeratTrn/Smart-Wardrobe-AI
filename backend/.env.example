# Sunucu Ayarları
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Veritabanı (MongoDB)
MONGO_URI=mongodb://localhost:27017/smartwardrobe_db

# Güvenlik (JWT)
# Şifrenizi oluşturmak için terminalde 'node -e "console.log(require(\"crypto\").randomBytes(32).toString(\"hex\"))"' çalıştırabilirsiniz
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Dış API Anahtarları
# OpenAI (Kıyafet Analiz ve Kombin Üretimi için)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenWeatherMap (Hava durumu bazlı kombin için)
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Cloudinary (Frontend/Mobil tarafından fotoğraf yüklemelerinde kullanılacaksa)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
